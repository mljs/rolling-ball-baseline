{
  "name": "ml-rolling-ball-baseline",
  "version": "2.0.3",
  "description": "Rolling ball baseline correction",
  "main": "./lib/index.js",
  "module": "./lib-esm/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib",
    "src",
    "lib-esm"
  ],
  "scripts": {
    "check-types": "tsc --noEmit",
    "clean": "rimraf lib lib-esm",
    "eslint": "eslint src",
    "eslint-fix": "npm run eslint -- --fix",
    "prepack": "npm run tsc",
    "prettier": "prettier --check src",
    "prettier-write": "prettier --write src",
    "test": "npm run test-only && npm run eslint && npm run prettier && npm run check-types",
    "test-only": "vitest run --coverage",
    "tsc": "npm run clean && npm run tsc-cjs && npm run tsc-esm",
    "tsc-cjs": "tsc --project tsconfig.cjs.json",
    "tsc-esm": "tsc --project tsconfig.esm.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mljs/rolling-ball-baseline.git"
  },
  "keywords": [],
  "author": "Kevin M. Jablonka",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mljs/rolling-ball-baseline/issues"
  },
  "homepage": "https://github.com/mljs/rolling-ball-baseline#readme",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "cheminfo-types": "^1.15.0",
    "eslint": "^8.57.0",
    "eslint-config-cheminfo-typescript": "^12.2.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "is-any-array": "^3.0.0",
    "ml-spectra-processing": "^14.28.1"
  }
}
